{
    "name": "msgpack-typed",
    "version": "0.0.0",
    "description": "A MessagePack encoder and decoder implementation focused on type preservation and interoperability with other codecs",

    "homepage": "https://github.com/osoclos/msgpack-typed",

    "license": "MIT",
    "author": {
        "name": "osoclos",
        "email": "osoclosus@gmail.com",

        "url": "https://github.com/osoclos"
    },

    "repository": {
        "type": "git",
        "url": "git+https://github.com/osoclos/msgpack-typed.git"
    },

    "bugs": {
        "email": "osoclosus@gmail.com",
        "url": "https://github.com/osoclos/msgpack-typed/issues"
    },

    "private": false,

    "type": "module",

    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",

    "files": ["dist"],
    "exports": {
        ".": "./dist/index.js",
        "./package.json": "./package.json"
    },

    "scripts": {
        "dev": "concurrently 'tsdown --watch' 'vitest watch'",

        "build": "tsdown",
        "test": "vitest",

        "bump": "tsdown && bumpp"
    },

    "devDependencies": {
        "tsdown": "^0.20.3",

        "vitest": "^4.0.18",
        "@vitest/browser-preview": "^4.0.18",

        "vite-plugin-wat2wasm": "^1.2.0",

        "typescript": "~5.9.3",

        "@types/node": "^25.3.2",

        "bumpp": "^10.4.1",
        "concurrently": "^9.2.1"
    }
}
